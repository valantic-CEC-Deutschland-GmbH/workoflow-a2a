# Platform API (no credentials needed - personal token auth, forwarded per call)
WORKOFLOW_API_URL=http://localhost:3979

# Orchestrator (LAN-only ADK service). The A2A server proxies to its webhook.
ORCHESTRATOR_URL=http://localhost:8080
WEBHOOK_AUTH_TOKEN=
ORCHESTRATOR_TIMEOUT_SECONDS=600

# Public identity advertised in the agent card
PUBLIC_BASE_URL=http://localhost:9008
AGENT_NAME=Workoflow Bot
AGENT_VERSION=0.1.0

# Auth phase: personal_token (phase 1). oidc / ias land later (see README).
AUTH_PHASE=personal_token

# Tracing (Phoenix integration); presence of the endpoint enables OTEL
OTEL_SERVICE_NAME=workoflow-a2a
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Error tracking (Sentry); presence of the DSN enables Sentry (opt-in)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
